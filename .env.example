# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret-if-needed
AWS_REGION=us-east-1

# DynamoDB Configuration
DYNAMODB_USERS_TABLE=users-development
DYNAMODB_ACTIVITY_TABLE=user_activity-development
# DYNAMODB_ENDPOINT_URL=http://localhost:8000  # Uncomment for local DynamoDB

# Other configurations
OPENAI_API_KEY=your-openai-api-key-if-needed
ENVIRONMENT=development

# DynamoDB Table Names for Conversations
DYNAMODB_CONVERSATIONS_TABLE=mirror-conversations
DYNAMODB_MESSAGES_TABLE=mirror-conversation-messages

# Optional: For local development with DynamoDB Local
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# Conversation Service Configuration
MAX_CONTEXT_MESSAGES=30
MAX_TOKENS_PER_CONVERSATION=4000
CONVERSATION_TITLE_MAX_LENGTH=60

# Feature Flags
ENABLE_CONVERSATION_PERSISTENCE=true
ENABLE_CONVERSATION_SEARCH=false
ENABLE_MESSAGE_ENCRYPTION=false

# Performance Settings
CONVERSATION_CACHE_TTL=3600
MESSAGE_BATCH_SIZE=25

# ============================================================
# Reflection Room V1
# ============================================================

# Default IANA timezone used when user has no tz on record and no
# X-User-Timezone header. Drives session expiry and time-of-day buckets.
REFLECTION_DEFAULT_USER_TZ=America/New_York

# Configuration file paths (relative to repo root).
REFLECTION_QUIZ_RULES_PATH=src/app/data/reflection/reflection_quiz_rules.v1.yaml
REFLECTION_MOTIF_MAPPING_PATH=src/app/data/reflection/motif_mapping.v1.json
REFLECTION_QUIZ_TO_LOOP_SEEDING_PATH=src/app/data/reflection/quiz_to_loop_seeding.v1.yaml
REFLECTION_TONE_LIBRARY_PATH=src/app/data/micro_practice/echo_signature_tone_library.v1.yaml
REFLECTION_PRACTICE_RULES_PATH=src/app/data/micro_practice/echo_practice_rules.v1.yaml
REFLECTION_PRACTICE_CATALOG_PATH=src/app/data/micro_practice/micro_practices.v1.yaml
REFLECTION_MICRO_PRACTICE_SETTINGS_PATH=src/app/data/micro_practice/micro_practice.settings.v1.yaml
REFLECTION_PERSONALIZATION_DEFAULTS_PATH=src/app/data/micro_practice/personalization.defaults.v1.json

# DynamoDB tables (env-suffixed at runtime; defaults shown for local dev)
DYNAMODB_REFLECTION_SESSIONS_TABLE=mc_reflection_sessions-development
DYNAMODB_ECHO_LOOP_STATE_TABLE=mc_echo_loop_state-development
DYNAMODB_PRACTICE_COMPLETIONS_TABLE=mc_practice_completions-development
DYNAMODB_USER_PERSONALIZATION_TABLE=mc_user_personalization-development

# MirrorGPT Memory — Life Anchors (Phase 2)
DYNAMODB_LIFE_ANCHORS_TABLE=mc_life_anchors-development

# Echo share viewer (email-recipient attachment playback)
# SHARE_TOKEN_SECRET: signs the share JWT. REQUIRED. Generate with:
#   openssl rand -base64 48
# Use a DIFFERENT value per environment; rotating it revokes all share links.
SHARE_TOKEN_SECRET=
# SHARE_BASE_URL: public origin serving the /share/* routes (the API Gateway
# URL, or a CloudFront distro that forwards /share/* to the API).
SHARE_BASE_URL=https://ct3onxgeol.execute-api.us-east-1.amazonaws.com

# Rich echo-share email brand assets (logo, dividers, icons). Public base URL
# (no trailing slash) where the 8 images live; templates load them as
# ${EMAIL_ASSET_BASE_URL}/<name>.png. Leave unset to use the per-stage public
# bucket created by serverless.yml:
#   https://mirror-collective-email-assets-<stage>.s3.us-east-1.amazonaws.com
# Set this only to point at a different host (e.g. a shared bucket or CloudFront).
EMAIL_ASSET_BASE_URL=
